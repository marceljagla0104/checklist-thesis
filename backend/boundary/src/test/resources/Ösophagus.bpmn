      <bpmn:sequenceFlow id="Flow_1t0k02u" name="No" sourceRef="Gateway_0xp0gwa" targetRef="Gateway_0ygxoan" />
      <bpmn:sequenceFlow id="Flow_03vgtpe" sourceRef="Activity_1oimphe" targetRef="Activity_0the8nz" />
      <bpmn:association id="Association_0qnwgs8" sourceRef="Activity_0kcvg7m" targetRef="TextAnnotation_0rcdz2g" />
      <bpmn:association id="Association_0fkhzc7" sourceRef="Activity_18ftu4f" targetRef="TextAnnotation_0dg4712" />
      <bpmn:association id="Association_0wslvc3" sourceRef="Activity_11mn6vg" targetRef="TextAnnotation_1uu1eiy" />
      <bpmn:association id="Association_12nki7j" sourceRef="Activity_1c62fss" targetRef="TextAnnotation_0zao25b" />
      <bpmn:textAnnotation id="TextAnnotation_0rcdz2g">
        <bpmn:text>Supine position</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0dg4712">
        <bpmn:text>Left subcostal access with Verres needle, To ~ 15 mmHg</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1uu1eiy">
        <bpmn:text>3x 8 mm and 1x 12 mm ports in a line three cross fingers under the costal arch (for R2, 8mm: on the midline slightly above or at the umbilicus; for R3, 8 mm: on the left mid-clavicular line (MCL) at least 8 cm away from R2 on a straight line; for R4, 8 mm: as far left lateral from R3 as possible; for R1, 12 mm: on right MCL at least 8 cm away from R2); 1x 12-mm assisting port triangulated midway inferior between R2 and R1; 1x 5 mm port for liver retractor subcostally on the right MCL</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0s3i96k">
        <bpmn:text>Suspected peritoneal carcinomatosis or liver metastasis</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0vyitzv" sourceRef="Event_11p9mls" targetRef="TextAnnotation_0s3i96k" />
      <bpmn:textAnnotation id="TextAnnotation_0zao25b">
        <bpmn:text>Rule out peritoneal carcinomatosis or liver metastases</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1hl5una" sourceRef="Activity_0b9q2rr" targetRef="TextAnnotation_072p3jy" />
      <bpmn:association id="Association_1i7b998" sourceRef="Activity_0qays57" targetRef="TextAnnotation_0q5ezwz" />
      <bpmn:association id="Association_1h9tipi" sourceRef="Activity_0op0sy6" targetRef="TextAnnotation_10pvdwz" />
      <bpmn:association id="Association_1w5kfi1" sourceRef="Gateway_1epekwv" targetRef="TextAnnotation_15db9y7" />
      <bpmn:textAnnotation id="TextAnnotation_10pvdwz">
        <bpmn:text>R1: Fenestrated bipolar forceps, R2: 30° endoscope, R3: Permanent cautery hook or EndoWrist® Vessel Sealer, R4: Tip-up fenestrated grasper</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0q5ezwz">
        <bpmn:text>Table in reverse Trendelenburg position (~ 15°) and a ~ 10° rotation to the right</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_072p3jy">
        <bpmn:text>Elevation of the right liver lobe</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_175l3c6">
        <bpmn:text>Too many abdominal adhesions</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0sve6yx" sourceRef="Event_09b9vq9" targetRef="TextAnnotation_175l3c6" />
      <bpmn:textAnnotation id="TextAnnotation_15db9y7">
        <bpmn:text>Are disturbing adhesions present?</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1ukh3cu" sourceRef="Activity_1e0qpxh" targetRef="TextAnnotation_0drw3pd" />
      <bpmn:association id="Association_0vf5r0h" sourceRef="Activity_13lqn8o" targetRef="TextAnnotation_11s9e76" />
      <bpmn:association id="Association_00owluj" sourceRef="Gateway_10fkw0k" targetRef="TextAnnotation_0d95954" />
      <bpmn:association id="Association_1l2d8hm" sourceRef="Activity_1n3lo2z" targetRef="TextAnnotation_0ofe4s4" />
      <bpmn:association id="Association_1pwkuf1" sourceRef="Gateway_16opyli" targetRef="TextAnnotation_0gz7tff" />
      <bpmn:association id="Association_05yr0a2" sourceRef="Activity_18y1g0w" targetRef="TextAnnotation_1ept897" />
      <bpmn:textAnnotation id="TextAnnotation_0d95954">
        <bpmn:text>Do you want to perform the step"Resection of splenic artery lymph nodes"?</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0gz7tff">
        <bpmn:text>Do you want to perform the  step"Dorsal gastrolysis until gastroduodenal artery is reached"?</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_11s9e76">
        <bpmn:text>Resection of lymph node station 17</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0ofe4s4">
        <bpmn:text>Dissection until duodenum is visible, Mobilization of the hepatic flexure as far as needed to allow tension free movement of the pylorus, Caution: Preservation of the right gastroepiploic vascular arcade</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0drw3pd">
        <bpmn:text>Dissection until cardial notch is reached,Caution:Preservation of the gastroepiploic vascular arcade</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0dtrmtv">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0trk7l5" sourceRef="Event_0wrhrzv" targetRef="TextAnnotation_0dtrmtv" />
      <bpmn:textAnnotation id="TextAnnotation_0ow7foq">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1mr7thg" sourceRef="Event_0erpv1e" targetRef="TextAnnotation_0ow7foq" />
      <bpmn:textAnnotation id="TextAnnotation_02t0l98">
        <bpmn:text>Injuring the right gastroepiploic vascular arcade</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1lnzkrm" sourceRef="Event_1jozd7r" targetRef="TextAnnotation_02t0l98" />
      <bpmn:textAnnotation id="TextAnnotation_18qdqt4">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_10ej8fd" sourceRef="Event_1muazyl" targetRef="TextAnnotation_18qdqt4" />
      <bpmn:textAnnotation id="TextAnnotation_1ept897">
        <bpmn:text>To the upper pole of the spleen including upper small gastric vessels</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_099ly0w">
        <bpmn:text>Persisting hiatal hernia</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_15c2flx" sourceRef="Event_1qr61h9" targetRef="TextAnnotation_099ly0w" />
      <bpmn:association id="Association_0cv1y9a" sourceRef="Gateway_0t6sfya" targetRef="TextAnnotation_0xhmj39" />
      <bpmn:association id="Association_0ohaquo" sourceRef="Activity_1xgwmkc" targetRef="TextAnnotation_02vapti" />
      <bpmn:association id="Association_1opka3w" sourceRef="Activity_1rqroz6" targetRef="TextAnnotation_15567w0" />
      <bpmn:association id="Association_0pmx69z" sourceRef="Gateway_1crmzzu" targetRef="TextAnnotation_0ksa3r7" />
      <bpmn:association id="Association_110aq6n" sourceRef="Gateway_0jsmk9s" targetRef="TextAnnotation_1375usn" />
      <bpmn:association id="Association_0cyf6f5" sourceRef="Activity_0rk1imj" targetRef="TextAnnotation_0tg72ek" />
      <bpmn:association id="Association_0byhcwx" sourceRef="Gateway_09fr1vh" targetRef="TextAnnotation_14w39t9" />
      <bpmn:association id="Association_0gp6aiq" sourceRef="Activity_15feqr2" targetRef="TextAnnotation_0p1jdiv" />
      <bpmn:textAnnotation id="TextAnnotation_0xhmj39">
        <bpmn:text>Does the patient have a gallbladder?</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0ksa3r7">
        <bpmn:text>Do you want to perform the step"Dorsal gastrolysis until gastroduodenal artery is reached"?</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_14w39t9">
        <bpmn:text>Do you want to perform the step"Cholecystectomy"?</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1375usn">
        <bpmn:text>Do you want to perform the step"Resection of splenic artery lymph nodes"?</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0tg72ek">
        <bpmn:text>Resection of lymph node station 17</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0p1jdiv">
        <bpmn:text>Caution:Do not injure the right hepatic artery</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_02vapti">
        <bpmn:text>Start at the Crow`s foot stapling (DaVinci left hand) the stomach vertical to the small gastric curvature, then stapling multiple times parallel to the great gastric curvature to create the initial part of the tube; 4,5 cm diameter</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0l47k6d">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1qfit74" sourceRef="Event_1salmg2" targetRef="TextAnnotation_0l47k6d" />
      <bpmn:textAnnotation id="TextAnnotation_0x0pf6n">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1fmoauf" sourceRef="Event_0s7pc9x" targetRef="TextAnnotation_0x0pf6n" />
      <bpmn:textAnnotation id="TextAnnotation_0kgkbxz">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_079hj2x" sourceRef="Event_001dzra" targetRef="TextAnnotation_0kgkbxz" />
      <bpmn:textAnnotation id="TextAnnotation_092hvlm">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_11twgci" sourceRef="Event_1hvi1y4" targetRef="TextAnnotation_092hvlm" />
      <bpmn:textAnnotation id="TextAnnotation_15567w0">
        <bpmn:text>Resection of lymph node stations 19 and 18, Resection of lymph nodes along hepatoduodenal ligament until portal vein</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_04q2n9l">
        <bpmn:text>Resection of  Common hepatic artery lymph nodes</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0pbwl02" sourceRef="Event_061ks1f" targetRef="TextAnnotation_04q2n9l" />
      <bpmn:textAnnotation id="TextAnnotation_11lp0m9">
        <bpmn:text>Hemostasis because of  njuring the right hepatic artery</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0t7tzkw" sourceRef="Event_0z23xel" targetRef="TextAnnotation_11lp0m9" />
      <bpmn:textAnnotation id="TextAnnotation_0uynfe0">
        <bpmn:text>Resection of  Hepatoduodenal ligament lymph nodes</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0pdl1x8" sourceRef="Event_02rzykz" targetRef="TextAnnotation_0uynfe0" />
      <bpmn:association id="Association_1k6u89p" sourceRef="Activity_0the8nz" targetRef="TextAnnotation_0e2h0y5" />
      <bpmn:association id="Association_168neb9" sourceRef="Activity_03xrze8" targetRef="TextAnnotation_0w4v38k" />
      <bpmn:association id="Association_1yxhuwa" sourceRef="Activity_134c0y4" targetRef="TextAnnotation_169x9i2" />
      <bpmn:association id="Association_1qpdyq8" sourceRef="Activity_1s3v5h5" targetRef="TextAnnotation_015ejrh" />
      <bpmn:association id="Association_1fi262q" sourceRef="Activity_1xbwpqw" targetRef="TextAnnotation_06n6jmv" />
      <bpmn:association id="Association_1bz379o" sourceRef="Activity_1796zib" targetRef="TextAnnotation_0bsa1g2" />
      <bpmn:association id="Association_1af0b51" sourceRef="Gateway_1y3e10p" targetRef="TextAnnotation_0dj0kl7" />
      <bpmn:association id="Association_09layd3" sourceRef="Gateway_0xp0gwa" targetRef="TextAnnotation_1dfa8cv" />
      <bpmn:textAnnotation id="TextAnnotation_1dfa8cv">
        <bpmn:text>Does the patient have a gallbladder?</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0dj0kl7">
        <bpmn:text>Does the patient have a lot of fluid at the operative site?</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_015ejrh">
        <bpmn:text>Resection of paracardial lymph nodes (lymph node station 14 R&amp;L)</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_169x9i2">
        <bpmn:text>Caution: Do not injure the right hepatic artery</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_099d8by">
        <bpmn:text>Resection of  Lower mediastinal paraesohageal lymph nodes</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0prjxvm" sourceRef="Event_0ryq0td" targetRef="TextAnnotation_099d8by" />
      <bpmn:textAnnotation id="TextAnnotation_10ymqza">
        <bpmn:text>Resection of  Pulmonary ligament lymph nodes</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_13t6va8" sourceRef="Event_0f3rm03" targetRef="TextAnnotation_10ymqza" />
      <bpmn:textAnnotation id="TextAnnotation_0bjo8pt">
        <bpmn:text>Resection of  Paracardial lymph nodes</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1eif4cg" sourceRef="Event_1hlcx7r" targetRef="TextAnnotation_0bjo8pt" />
      <bpmn:textAnnotation id="TextAnnotation_1fh65qy">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1aiza84" sourceRef="Event_01hd3en" targetRef="TextAnnotation_1fh65qy" />
      <bpmn:textAnnotation id="TextAnnotation_1e8v973">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1wfsm8v" sourceRef="Event_0ip2hwy" targetRef="TextAnnotation_1e8v973" />
      <bpmn:textAnnotation id="TextAnnotation_1ky924w">
        <bpmn:text>Hemostasis because of injuring the heart, the aorta</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_10mbhcw" sourceRef="Event_0e5n8r8" targetRef="TextAnnotation_1ky924w" />
      <bpmn:textAnnotation id="TextAnnotation_0uf4p4w">
        <bpmn:text>Hemostasis because of injuring the heart</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0coxibm" sourceRef="Event_0fcuonv" targetRef="TextAnnotation_0uf4p4w" />
      <bpmn:textAnnotation id="TextAnnotation_0e2h0y5">
        <bpmn:text>Resection of lymph node station 15</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0w4v38k">
        <bpmn:text>Resection of lymph node station 16</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_06n6jmv">
        <bpmn:text>Resection of pulmonary ligament lymph nodes (lymph node station 13 R&amp;L) If possible: do not open the left pleura to prevent hiatal hernias</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0bsa1g2">
        <bpmn:text>Partly resection of lower mediastinal paraesophageal lymph nodes (lymph node station 12 R&amp;L)</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_16t8pa8">
        <bpmn:text>Hemostasis because of  injuring the right hepatic artery</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_05ex4uj" sourceRef="Event_0ormyaa" targetRef="TextAnnotation_16t8pa8" />
    </bpmn:subProcess>

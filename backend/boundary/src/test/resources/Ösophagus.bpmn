      <bpmn:sequenceFlow id="Flow_0j3cuvh" sourceRef="Activity_0jxv8fc" targetRef="Gateway_1y3e10p" />
      <bpmn:sequenceFlow id="Flow_0uwkw46" name="Yes" sourceRef="Gateway_1y3e10p" targetRef="Activity_1wv8n4a" />

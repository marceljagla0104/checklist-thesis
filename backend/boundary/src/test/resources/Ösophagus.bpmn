      <bpmn:sequenceFlow id="Flow_0xjlm5o" sourceRef="Event_0hhp4r3" targetRef="Activity_00pkkha" />
      <bpmn:sequenceFlow id="Flow_1gig773" sourceRef="Activity_00pkkha" targetRef="Gateway_15op61e" />
      <bpmn:textAnnotation id="TextAnnotation_0jxsq44">
        <bpmn:text>Left lateral decubitus position with the table in a modified prone position
(~ 45°rotation of the lateral chest)</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0v0qczf">
        <bpmn:text>For R4 in the 4th intercostal space (ICS), 1 cm medial to the scapula; for R3 in the 6th ICS, slightly more medial than port 4; for R2 in the 8th ICS at the same level as port 4; for R1 on the scapular line or slightly posterior in the 10th ICS. A 6–10- cm spacing is maintained between ports; for the assisting port in the 9th ICS triangulated between R1 and R2 (this would be the site for specimen removal and entrance of circular stapler) or triangulated between R3 and R4 in the 5th ICS</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0fzoz04">
        <bpmn:text>To ~ 8 mmHg</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0vsa7qj">
        <bpmn:text>4x 8 mm ports for robotic arms</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0n31m02">
        <bpmn:text>From 3-4 cm above the azygos vein arcus to the hiatus., Resection of middle and lower mediastinal paraesophageal lymph nodes (lymph node stations 11 R, 12 R)</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_14jc9wl">
        <bpmn:text>One along the esophago-gastrostomy, one ventrally on the diaphragmatic dome for air</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0rcebb0">
        <bpmn:text>Resection of  Middle mediastinal paraesophageal lymph nodes</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_07b4tf5">
        <bpmn:text>Resection of  Subcarinal lymph nodes</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1824vxi">
        <bpmn:text>Resection of  Lower paratracheal lymph nodes</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0yzs7nk">
        <bpmn:text>D2 -Lymphadenectomy</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_08mv4qd">
        <bpmn:text>Lung texture affected</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_16b0602">
        <bpmn:text>Hemostasis because of injuring the azygos vein</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0nzchk6">
        <bpmn:text>Hemostasis because of injuring the aorta,the azygos vein</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0ymajc8">
        <bpmn:text>Hemostasis because of injuring the pericardium, the aorta</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1sbqxr4">
        <bpmn:text>Hemostasis because of bleeding</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0v1hcmg">
        <bpmn:text>Section is not cancer free</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0tvav0h">
        <bpmn:text>Circular stapler anvil does not fit into the esophageal stump</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_02xy95t">
        <bpmn:text>False estimation of the tractive force necessary for stomach pull-up --&gt; damaging the gastric conduit</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_026qol1">
        <bpmn:text>Threads of the sutures break</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0e5bdij">
        <bpmn:text>R1: Tip-up fenestrated grasper, R2: Fenestrated bipolar forceps, R3: 30° endoscope, R4: Permanent cautery hook or Monopolar curved scissors or EndoWrist® Vessel Sealer</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1o2wdvg">
        <bpmn:text>Resection of lower and middle mediastinal paraesophageal and subcarinal lymph nodes (lymph node stations 12 L, 11 L, 9)</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1byar2f">
        <bpmn:text>Resection of aortopulmonary window, upper mediastinal paraesophageal, lower and upper paratracheal lymph nodes (lymph node stations 8, 10 R&amp;L, 7 R&amp;L, 6 R&amp;L)</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0vf81b5">
        <bpmn:text>Four holding sutures at 12, 3, 6 and 9 o`clock with fixation of the esophageal mucosa to the muscular wall. Purse-string suture for fixation of the anvil.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_14blzmj">
        <bpmn:text>Pull-up until the gastric tube is located in the right thoracic cavity</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0ymota2">
        <bpmn:text>Out of the thorax through the mini-thoracotomy</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1oy30px">
        <bpmn:text>28mm tri-stapler into the stomach conduit bringing it back to the thorax</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0lc5db8">
        <bpmn:text>Separate dissection of the greater omentum and gastroepiploic vessels.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0zfyg1u">
        <bpmn:text>3-0 Stratafix</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_05fdaev">
        <bpmn:text>Anastomosis insufficiency (visible with ICG)</bpmn:text>
      </bpmn:textAnnotation>
